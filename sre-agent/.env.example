GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-east1

# ---- Jira webhook -------------------------------------------------------

# Values written into the secret. Copy these into your .env and fill them in
# before running `make deploy-webhook`. They are NOT baked into the function;
# the script writes them to Secret Manager and the function reads from there.
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=replace-with-jira-api-token
JIRA_WEBHOOK_SECRET=replace-with-shared-webhook-secret
JIRA_PROJECT_KEY=replace-with-jira-project-key
